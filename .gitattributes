# Auto detect text files and perform LF normalization
* text=auto

# Rust source files
*.rs text
Cargo.toml text
Cargo.lock text

# Shell scripts
*.sh text eol=lf

# Python files
*.py text
*.pyx text

# Markdown and documentation
*.md text
*.txt text
*.rst text

# Binary files (should not be normalized)
*.png binary
*.jpg binary
*.gif binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary

# Git merge strategy for lock files
Cargo.lock merge=union